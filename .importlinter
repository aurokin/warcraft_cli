[importlinter]
root_packages =
  warcraft_core
  warcraft_api
  warcraft_content
  wowhead_cli
  method_cli
  icy_veins_cli
  raiderio_cli
  warcraft_wiki_cli
  wowprogress_cli
  simc_cli
  warcraftlogs_cli
  raidbots_cli
  blizzard_api_cli
  curseforge_cli
  lorrgs_cli
  warcraft_cli

[importlinter:contract:providers-independent]
name = Provider CLIs do not import each other
type = independence
modules =
  wowhead_cli
  method_cli
  icy_veins_cli
  raiderio_cli
  warcraft_wiki_cli
  wowprogress_cli
  simc_cli
  warcraftlogs_cli
  raidbots_cli
  blizzard_api_cli
  curseforge_cli
  lorrgs_cli
ignore_imports =
  warcraftlogs_cli.main -> simc_cli.talent_transport

[importlinter:contract:package-layers]
name = Shared core layering and wrapper on top
type = layers
layers =
  warcraft_cli
  wowhead_cli | method_cli | icy_veins_cli | raiderio_cli | warcraft_wiki_cli | wowprogress_cli | simc_cli | warcraftlogs_cli | raidbots_cli | blizzard_api_cli | curseforge_cli | lorrgs_cli
  warcraft_api | warcraft_content
  warcraft_core
ignore_imports =
  warcraftlogs_cli.main -> simc_cli.talent_transport
